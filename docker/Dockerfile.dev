# Dev image — tools only, compile at runtime with cache volumes.
# Generated by generate.py — edit there, not here.
#
# Local:  docker build -t hookz-xahaud-dev -f Dockerfile.dev .
# CI:     docker build --build-arg BASE_IMAGE=gcr.io/xprv-server/hookz-conan-deps -t gcr.io/xprv-server/hookz-xahaud-dev -f Dockerfile.dev .
# Run:    docker run --rm -v hookz-ccache:/ccache hookz-xahaud-dev "ripple.app.SetHook"

ARG BASE_IMAGE=hookz-conan-deps:latest
FROM ${BASE_IMAGE}

# Extra tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    ccache \
    wabt \
    clang-format \
    && rm -rf /var/lib/apt/lists/*

ARG HOOKZ_REPO=https://github.com/sublimator/hookz.git
ARG HOOKZ_BRANCH=main
ARG SCRIPTS_REPO=https://github.com/sublimator/xahaud-scripts.git
ARG SCRIPTS_BRANCH=main
ARG WASI_SDK_VERSION=32

# uv + hookz + xahaud-scripts
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"
RUN uv tool install "hookz @ git+${HOOKZ_REPO}@${HOOKZ_BRANCH}"
RUN uv tool install "xahaud-scripts @ git+${SCRIPTS_REPO}@${SCRIPTS_BRANCH}"

ARG TARGETARCH
RUN ARCH=$([ "$TARGETARCH" = "arm64" ] && echo "arm64" || echo "x86_64") \
    && curl -sSL https://github.com/WebAssembly/wasi-sdk/releases/download/wasi-sdk-${WASI_SDK_VERSION}/wasi-sdk-${WASI_SDK_VERSION}.0-${ARCH}-linux.tar.gz \
    | tar xz -C /opt \
    && ln -s /opt/wasi-sdk-${WASI_SDK_VERSION}.0-${ARCH}-linux /opt/wasi-sdk
ENV WASI_SDK_PATH=/opt/wasi-sdk

ENV CCACHE_DIR=/ccache
ENV CCACHE_CONFIGPATH=/root/.config/xahaud-scripts/ccache.conf
RUN mkdir -p /ccache /root/.config/xahaud-scripts

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["ripple.app.SetHook"]
