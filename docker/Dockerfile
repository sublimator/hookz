# Baked xahaud image. Works without volumes.
# Generated by generate.py — edit there, not here.
#
# First build:
#   docker build -t hookz-xahaud .
#
# Incremental rebuild (reuses ccache from previous image):
#   docker build --build-arg PREV_IMAGE=hookz-xahaud:latest -t hookz-xahaud .
#
# Cloud build (pulls previous from registry for ccache, if it exists):
#   docker build --build-arg BASE_IMAGE=gcr.io/xprv-server/hookz-conan-deps \
#                --build-arg PREV_IMAGE=gcr.io/xprv-server/hookz-xahaud -t gcr.io/xprv-server/hookz-xahaud .
#
# Run:
#   docker run --rm hookz-xahaud "ripple.app.SetHook"
#
# With external tests + writable ccache volume:
#   docker run --rm -v hookz-ccache:/ccache \
#     -v ~/my-hooks/tests:/tests \
#     -e HOOKS_TEST_DIR=/tests \
#     hookz-xahaud "ripple.app.TipBot"
#
# ccache layout:
#   /ccache-primed  — read-only file backend baked into image (from reshare)
#   /ccache         — writable local cache (CCACHE_DIR), mountable volume
#   Config lives at /root/.config/xahaud-scripts/ccache.conf (x-run-tests
#   bakes this path into the cmake wrapper toolchain).
#   Build-time: misses write to local + reshare to /ccache-primed.
#   Runtime: hits from /ccache, fallback to /ccache-primed, misses to /ccache.

# Global ARGs (before any FROM, available to all stages)
ARG PREV_IMAGE
ARG BASE_IMAGE=hookz-conan-deps:latest

# Optional: previous image to seed ccache from. Defaults to a dummy stage
# with an empty /ccache-primed dir so COPY --from=prev always succeeds.
FROM ${PREV_IMAGE:-ubuntu:24.04} AS prev
RUN mkdir -p /ccache-primed

FROM ${BASE_IMAGE}

# Extra tools not needed for conan but needed for xahaud build/test
RUN apt-get update && apt-get install -y --no-install-recommends \
    ccache \
    wabt \
    clang-format \
    && rm -rf /var/lib/apt/lists/*

ARG HOOKZ_REPO=https://github.com/sublimator/hookz.git
ARG HOOKZ_BRANCH=main
ARG SCRIPTS_REPO=https://github.com/sublimator/xahaud-scripts.git
ARG SCRIPTS_BRANCH=main
ARG XAHAUD_BRANCH=external-env-tests
ARG WASI_SDK_VERSION=32

# uv + hookz + xahaud-scripts
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"
RUN uv tool install "hookz @ git+${HOOKZ_REPO}@${HOOKZ_BRANCH}"
RUN uv tool install "xahaud-scripts @ git+${SCRIPTS_REPO}@${SCRIPTS_BRANCH}"

ARG TARGETARCH
RUN ARCH=$([ "$TARGETARCH" = "arm64" ] && echo "arm64" || echo "x86_64") \
    && curl -sSL https://github.com/WebAssembly/wasi-sdk/releases/download/wasi-sdk-${WASI_SDK_VERSION}/wasi-sdk-${WASI_SDK_VERSION}.0-${ARCH}-linux.tar.gz \
    | tar xz -C /opt \
    && ln -s /opt/wasi-sdk-${WASI_SDK_VERSION}.0-${ARCH}-linux /opt/wasi-sdk
ENV WASI_SDK_PATH=/opt/wasi-sdk

# Pull latest xahaud source (base image has a shallow clone that may be stale)
RUN git fetch origin ${XAHAUD_BRANCH} && git checkout FETCH_HEAD

# ccache setup:
# - Seed /ccache-primed from previous image (empty on first build)
# - Use /ccache-build as temporary local cache during build
# - Reshare hits into /ccache-primed so the final image has a warm cache
ENV CCACHE_DIR=/ccache-build
ENV CCACHE_CONFIGPATH=/root/.config/xahaud-scripts/ccache.conf
ENV CCACHE_NOHASHDIR=true
RUN mkdir -p /ccache-build /ccache-primed /ccache /root/.config/xahaud-scripts
COPY --from=prev /ccache-primed/ /ccache-primed/
RUN printf 'remote_storage = file:/ccache-primed\nreshare = true\nhash_dir = false\nmax_size = 10G\n' > /root/.config/xahaud-scripts/ccache.conf

# Build xahaud using x-run-tests (handles conan, cmake, ccache wrapper toolchain)
# -j defaults to nproc; override with BUILD_JOBS to avoid OOM on high-CPU/low-RAM
ARG BUILD_JOBS
RUN x-run-tests --times=0 --ccache --reconfigure-build ${BUILD_JOBS:+-j $BUILD_JOBS}

# Validate
RUN ./build/rippled --version || true

# Finalize ccache:
# - Drop temporary build cache (don't ship it)
# - Repoint config to read-only primed cache for runtime
# - Set CCACHE_DIR to /ccache for runtime writes
RUN rm -rf /ccache-build \
    && printf 'remote_storage = file:/ccache-primed|read-only\nhash_dir = false\nmax_size = 10G\n' > /root/.config/xahaud-scripts/ccache.conf
ENV CCACHE_DIR=/ccache

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["ripple.app.SetHook"]
